generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  SUPERVISOR
  HOD
  FINANCE_DIRECTOR
  GENERAL_MANAGER
  SYSTEM_ADMINISTRATOR
}

enum DocumentStatus {
  DRAFT
  IN_REVIEW
  SIGNED_HOD
  SIGNED_FINANCE
  SIGNED_GM
  PUBLISHED
  REJECTED
  ARCHIVED
  NEEDS_REVIEW
}

enum DocumentCategory {
  POLICIES
  SOP
  FORMS
  CHECKLISTS
  TEMPLATES
  REPORTS
  CONTRACTS
  TRAINING_MATERIALS
  ARCHIVE
}

enum DocumentPriority {
  HIGH
  MEDIUM
  LOW
}

enum AuditAction {
  LOGIN
  LOGOUT
  VIEW
  DOWNLOAD
  PRINT
  CREATE
  UPDATE
  DELETE
  SIGN
  PUBLISH
  UNPUBLISH
  ARCHIVE
  APPROVE
  REJECT
  SUBMIT
}

model Department {
  id          String     @id @default(uuid())
  name        String     @unique
  code        String     @unique
  color       String     @default("#294660")
  location    String     @default("Main Hotel")
  description String?
  createdAt   DateTime   @default(now())
  users       User[]
  documents   Document[]
  templates   Template[]
}

model User {
  id           String            @id @default(uuid())
  email        String            @unique
  passwordHash String
  pinHash      String?
  firstName    String
  lastName     String
  role         Role              @default(EMPLOYEE)
  departmentId String?
  department   Department?       @relation(fields: [departmentId], references: [id])
  isActive        Boolean           @default(true)
  signatureImage  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  documents    Document[]        @relation("DocumentAuthor")
  ownedDocs    Document[]        @relation("DocumentOwner")
  auditLogs    AuditLog[]
  signatures   Signature[]
  comments     DocumentComment[]
  favorites    UserFavorite[]
}

model Document {
  id              String              @id @default(uuid())
  title           String
  code            String              @unique
  version         String              @default("1.0")
  description     String?
  content         String?
  status          DocumentStatus      @default(DRAFT)
  category        DocumentCategory
  priority        DocumentPriority    @default(MEDIUM)
  language        String              @default("English")
  tags            String              @default("[]")
  filePath        String?
  fileName        String?
  fileType        String?
  fileSize        Int?
  nextReviewDate  DateTime?
  effectiveDate   DateTime?
  archiveReason   String?
  archivedAt      DateTime?
  archivedBy      String?
  allowDownload   Boolean             @default(true)
  allowComments   Boolean             @default(true)
  departmentId    String
  department      Department          @relation(fields: [departmentId], references: [id])
  authorId        String
  author          User                @relation("DocumentAuthor", fields: [authorId], references: [id])
  ownerId         String?
  owner           User?               @relation("DocumentOwner", fields: [ownerId], references: [id])
  templateId      String?
  template        Template?           @relation(fields: [templateId], references: [id])
  workflowId      String?
  workflow        WorkflowRoute?      @relation(fields: [workflowId], references: [id])
  isLocked            Boolean             @default(false)
  signaturePlacement  String              @default("[]")
  pageCount           Int                 @default(1)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  history             DocumentHistory[]
  signatures      Signature[]
  versions        DocumentVersion[]
  comments        DocumentComment[]
  attachments     DocumentAttachment[]
  favorites       UserFavorite[]
}

model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  version    String
  filePath   String?
  changeNote String?
  createdBy  String
  createdAt  DateTime @default(now())
}

model DocumentHistory {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  action     String
  details    String?
  userId     String?
  userName   String?
  createdAt  DateTime @default(now())
}

model DocumentComment {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  text       String
  status     String   @default("open")
  createdAt  DateTime @default(now())
}

model DocumentAttachment {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fileName   String
  filePath   String
  fileSize   Int?
  fileType   String?
  createdAt  DateTime @default(now())
}

model Template {
  id           String           @id @default(uuid())
  name         String
  description  String?
  category     DocumentCategory
  content      String?
  version      String           @default("1.0")
  status       String           @default("Active")
  departmentId String?
  department   Department?      @relation(fields: [departmentId], references: [id])
  isActive           Boolean          @default(true)
  signaturePlacement String           @default("[]")
  pageCount          Int              @default(1)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  documents          Document[]
}

model WorkflowRoute {
  id          String     @id @default(uuid())
  name        String
  description String?
  steps       String
  isDefault   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  documents   Document[]
}

model Signature {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  fullName   String
  position   String
  signedAt   DateTime @default(now())
  ipAddress  String?
  device      String?
  docHash     String?
  imagePath   String?
  placementId String?
  page        Int?
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  userName   String?
  action     AuditAction
  entityType String?
  entityId   String?
  details    String?
  ipAddress  String?
  device     String?
  createdAt  DateTime    @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model SystemSettings {
  id                    String  @id @default("default")
  companyName           String  @default("HOTERRA Hotels & Resorts")
  companyAddress        String  @default("Baku, Azerbaijan")
  timezone              String  @default("Asia/Baku")
  dateFormat            String  @default("DD MMM YYYY")
  timeFormat            String  @default("24h")
  systemLanguage        String  @default("en")
  enableVersioning      Boolean @default(true)
  mandatoryReviewDate   Boolean @default(true)
  requireDescription    Boolean @default(false)
  allowDownload         Boolean @default(true)
  autoLogoutMinutes     Int     @default(30)
  recordsPerPage        Int     @default(20)
  enable2FA             Boolean @default(true)
  allowComments         Boolean @default(true)
  showTooltips          Boolean @default(true)
  defaultStartPage      String  @default("dashboard")
  defaultDocSort        String  @default("updated_desc")
  defaultDocStatus      String  @default("DRAFT")
  notifyEmail           Boolean @default(true)
  notifyPush            Boolean @default(true)
  notifyInApp           Boolean @default(true)
  extendedConfig        String  @default("{}")
}

model UserFavorite {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, documentId])
}
