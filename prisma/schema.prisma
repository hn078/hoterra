generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  SUPERVISOR
  HOD
  FINANCE_DIRECTOR
  GENERAL_MANAGER
  SYSTEM_ADMINISTRATOR
}

enum DocumentStatus {
  DRAFT
  IN_REVIEW
  SIGNED_HOD
  SIGNED_FINANCE
  SIGNED_GM
  PUBLISHED
  REJECTED
  ARCHIVED
  NEEDS_REVIEW
}

enum DocumentCategory {
  POLICIES
  SOP
  FORMS
  CHECKLISTS
  TEMPLATES
  REPORTS
  CONTRACTS
  TRAINING_MATERIALS
  ARCHIVE
}

enum DocumentPriority {
  HIGH
  MEDIUM
  LOW
}

enum AuditAction {
  LOGIN
  LOGOUT
  VIEW
  DOWNLOAD
  PRINT
  CREATE
  UPDATE
  DELETE
  SIGN
  PUBLISH
  UNPUBLISH
  ARCHIVE
  APPROVE
  REJECT
  SUBMIT
}

enum ConversationType {
  DIRECT
  DEPARTMENT
  HOTEL
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum WorkforceRequestStatus {
  PENDING
  AWAITING_EXTRA_APPROVAL
  APPROVED
  REJECTED
  SENT_TO_VENDOR
  VENDOR_ACCEPTED
  VENDOR_DECLINED
  COMPLETED
  CANCELLED
}

enum WorkforceVendorMode {
  DIRECT
  BROADCAST
}

enum WorkforceShift {
  MORNING
  EVENING
  NIGHT
  CUSTOM
}

model Department {
  id            String         @id @default(uuid())
  name          String         @unique
  code          String         @unique
  color         String         @default("#294660")
  location      String         @default("Main Hotel")
  description   String?
  createdAt     DateTime       @default(now())
  users         User[]
  documents     Document[]
  templates     Template[]
  conversations Conversation[]
  workforceRequests       WorkforceRequest[]
  workforceApprovalRoute  WorkforceApprovalRoute?
  casualBudgets           DepartmentCasualBudget[]
  workforceTemplates      WorkforceRequestTemplate[]
}

model User {
  id           String            @id @default(uuid())
  email        String            @unique
  passwordHash String
  pinHash      String?
  firstName    String
  lastName     String
  role         Role              @default(EMPLOYEE)
  departmentId String?
  department   Department?       @relation(fields: [departmentId], references: [id])
  isActive        Boolean           @default(true)
  signatureImage  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  documents    Document[]        @relation("DocumentAuthor")
  ownedDocs    Document[]        @relation("DocumentOwner")
  auditLogs    AuditLog[]
  signatures   Signature[]
  comments                DocumentComment[]
  favorites               UserFavorite[]
  conversationParticipants ConversationParticipant[]
  messages                Message[]
  workforceRequests       WorkforceRequest[]         @relation("WorkforceRequestCreator")
}

model Document {
  id              String              @id @default(uuid())
  title           String
  code            String              @unique
  version         String              @default("1.0")
  description     String?
  content         String?
  status          DocumentStatus      @default(DRAFT)
  category        DocumentCategory
  priority        DocumentPriority    @default(MEDIUM)
  language        String              @default("English")
  tags            String              @default("[]")
  filePath        String?
  fileName        String?
  fileType        String?
  fileSize        Int?
  nextReviewDate  DateTime?
  effectiveDate   DateTime?
  archiveReason   String?
  archivedAt      DateTime?
  archivedBy      String?
  allowDownload   Boolean             @default(true)
  allowComments   Boolean             @default(true)
  departmentId    String
  department      Department          @relation(fields: [departmentId], references: [id])
  authorId        String
  author          User                @relation("DocumentAuthor", fields: [authorId], references: [id])
  ownerId         String?
  owner           User?               @relation("DocumentOwner", fields: [ownerId], references: [id])
  templateId      String?
  template        Template?           @relation(fields: [templateId], references: [id])
  workflowId      String?
  workflow        WorkflowRoute?      @relation(fields: [workflowId], references: [id])
  isLocked            Boolean             @default(false)
  signaturePlacement  String              @default("[]")
  pageCount           Int                 @default(1)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  history             DocumentHistory[]
  signatures      Signature[]
  versions        DocumentVersion[]
  comments        DocumentComment[]
  attachments     DocumentAttachment[]
  favorites       UserFavorite[]
  attachedInMessages Message[]          @relation("MessageDocument")
  attachedInComments DocumentComment[]  @relation("CommentAttachedDocument")
}

model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  version    String
  filePath   String?
  changeNote String?
  createdBy  String
  createdAt  DateTime @default(now())
}

model DocumentHistory {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  action     String
  details    String?
  userId     String?
  userName   String?
  createdAt  DateTime @default(now())
}

model DocumentComment {
  id                 String    @id @default(uuid())
  documentId         String
  document           Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  text               String
  attachedDocumentId String?
  attachedDocument   Document? @relation("CommentAttachedDocument", fields: [attachedDocumentId], references: [id], onDelete: SetNull)
  attachmentFileName String?
  attachmentFilePath String?
  attachmentFileSize Int?
  attachmentFileType String?
  status             String    @default("open")
  createdAt          DateTime  @default(now())
}

model DocumentAttachment {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fileName   String
  filePath   String
  fileSize   Int?
  fileType   String?
  createdAt  DateTime @default(now())
}

model Template {
  id           String           @id @default(uuid())
  name         String
  description  String?
  category     DocumentCategory
  content      String?
  version      String           @default("1.0")
  status       String           @default("Active")
  departmentId String?
  department   Department?      @relation(fields: [departmentId], references: [id])
  isActive           Boolean          @default(true)
  signaturePlacement String           @default("[]")
  pageCount          Int              @default(1)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  documents          Document[]
}

model WorkflowRoute {
  id          String         @id @default(uuid())
  name        String
  description String?
  steps       String
  isDefault   Boolean        @default(false)
  status      WorkflowStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  documents   Document[]
}

model Signature {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  fullName   String
  position   String
  signedAt   DateTime @default(now())
  ipAddress  String?
  device      String?
  docHash     String?
  imagePath   String?
  placementId String?
  page        Int?
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  userName   String?
  action     AuditAction
  entityType String?
  entityId   String?
  details    String?
  ipAddress  String?
  device     String?
  createdAt  DateTime    @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model SystemSettings {
  id                    String  @id @default("default")
  companyName           String  @default("HOTERRA Hotels & Resorts")
  companyAddress        String  @default("Baku, Azerbaijan")
  timezone              String  @default("Asia/Baku")
  dateFormat            String  @default("DD MMM YYYY")
  timeFormat            String  @default("24h")
  systemLanguage        String  @default("en")
  enableVersioning      Boolean @default(true)
  mandatoryReviewDate   Boolean @default(true)
  requireDescription    Boolean @default(false)
  allowDownload         Boolean @default(true)
  autoLogoutMinutes     Int     @default(30)
  recordsPerPage        Int     @default(20)
  enable2FA             Boolean @default(true)
  allowComments         Boolean @default(true)
  showTooltips          Boolean @default(true)
  defaultStartPage      String  @default("dashboard")
  defaultDocSort        String  @default("updated_desc")
  defaultDocStatus      String  @default("DRAFT")
  notifyEmail           Boolean @default(true)
  notifyPush            Boolean @default(true)
  notifyInApp           Boolean @default(true)
  extendedConfig        String  @default("{}")
}

model UserFavorite {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, documentId])
}

model Conversation {
  id           String                    @id @default(uuid())
  type         ConversationType
  departmentId String?
  department   Department?               @relation(fields: [departmentId], references: [id])
  directKey    String?                   @unique
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]

  @@unique([type, departmentId])
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
}

model Message {
  id                 String       @id @default(uuid())
  conversationId     String
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId           String
  sender             User         @relation(fields: [senderId], references: [id])
  content            String
  documentId         String?
  document           Document?    @relation("MessageDocument", fields: [documentId], references: [id], onDelete: SetNull)
  attachmentFileName String?
  attachmentFilePath String?
  attachmentFileSize Int?
  attachmentFileType String?
  createdAt          DateTime     @default(now())
}

model WorkforcePosition {
  id        String             @id @default(uuid())
  name      String             @unique
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  requests  WorkforceRequest[]
  templates WorkforceRequestTemplate[]
}

model Vendor {
  id           String             @id @default(uuid())
  name         String             @unique
  contactEmail String?
  phone        String?
  isApproved   Boolean            @default(true)
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  selectedFor  WorkforceRequest[] @relation("SelectedVendor")
  acceptedFor  WorkforceRequest[] @relation("AcceptedVendor")
  invites      VendorInvite[]
  invoices     VendorInvoice[]
}

model WorkforceApprovalRoute {
  id           String     @id @default(uuid())
  departmentId String     @unique
  department   Department @relation(fields: [departmentId], references: [id])
  name         String
  steps        String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model DepartmentCasualBudget {
  id           String     @id @default(uuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  year         Int
  month        Int
  budgetAmount Float
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([departmentId, year, month])
}

model WorkforceSettings {
  id                     String  @id @default("default")
  hotelName              String  @default("HOTERRA")
  hotelsJson             String  @default("[\"HOTERRA\"]")
  minLeadHours           Int     @default(24)
  estimatedHourlyRate    Float   @default(15)
  estimatedHoursPerShift Float   @default(8)
  notifyEmail            Boolean @default(true)
  notifyPush             Boolean @default(true)
  payrollTolerancePct    Float   @default(5)
}

model WorkforceRequest {
  id                   String                 @id @default(uuid())
  code                 String                 @unique
  hotelName            String                 @default("HOTERRA")
  departmentId         String
  department           Department             @relation(fields: [departmentId], references: [id])
  positionId           String
  position             WorkforcePosition      @relation(fields: [positionId], references: [id])
  workDate             DateTime
  shift                WorkforceShift         @default(MORNING)
  startTime            String?
  endTime              String?
  quantity             Int
  comment              String?
  vendorMode           WorkforceVendorMode    @default(DIRECT)
  vendorId             String?
  vendor               Vendor?                @relation("SelectedVendor", fields: [vendorId], references: [id])
  acceptedVendorId     String?
  acceptedVendor       Vendor?                @relation("AcceptedVendor", fields: [acceptedVendorId], references: [id])
  broadcastVendorIds   String                 @default("[]")
  status               WorkforceRequestStatus @default(PENDING)
  currentStepIndex     Int                    @default(0)
  approvalSteps        String                 @default("[]")
  needsExtraApproval   Boolean                @default(false)
  isUrgentOverride     Boolean                @default(false)
  estimatedCost        Float?
  createdById          String
  createdBy            User                   @relation("WorkforceRequestCreator", fields: [createdById], references: [id])
  actualQuantity       Int?
  actualHours          Float?
  actualCost           Float?
  hodConfirmedAt       DateTime?
  hodConfirmedById     String?
  financeConfirmedAt   DateTime?
  financeConfirmedById String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  events               WorkforceRequestEvent[]
  invites              VendorInvite[]
  invoices             VendorInvoice[]
}

model WorkforceRequestEvent {
  id        String           @id @default(uuid())
  requestId String
  request   WorkforceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  userId    String?
  userName  String?
  createdAt DateTime         @default(now())
}

model WorkforceRequestTemplate {
  id              String              @id @default(uuid())
  name            String
  departmentId    String?
  department      Department?         @relation(fields: [departmentId], references: [id])
  positionId      String?
  position        WorkforcePosition?  @relation(fields: [positionId], references: [id])
  shift           WorkforceShift      @default(MORNING)
  quantity        Int                 @default(1)
  comment         String?
  dayOfWeek       Int?
  vendorMode      WorkforceVendorMode @default(DIRECT)
  vendorId        String?
  isActive        Boolean             @default(true)
  isRecurring     Boolean             @default(false)
  lastGeneratedAt DateTime?
  hotelName       String?
  createdAt       DateTime            @default(now())
}

model VendorInvite {
  id          String           @id @default(uuid())
  token       String           @unique
  requestId   String
  request     WorkforceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  vendorId    String
  vendor      Vendor           @relation(fields: [vendorId], references: [id])
  status      String           @default("PENDING")
  sentAt      DateTime         @default(now())
  respondedAt DateTime?
  expiresAt   DateTime
}

model VendorInvoice {
  id            String           @id @default(uuid())
  requestId     String
  request       WorkforceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  vendorId      String
  vendor        Vendor           @relation(fields: [vendorId], references: [id])
  invoiceNumber String
  invoiceHours  Float
  invoiceAmount Float
  invoiceDate   DateTime         @default(now())
  status        String           @default("PENDING")
  matchedAt     DateTime?
  notes         String?
  createdAt     DateTime         @default(now())
}

model EmailOutbox {
  id         String    @id @default(uuid())
  toEmail    String
  subject    String
  body       String
  entityType String?
  entityId   String?
  status     String    @default("QUEUED")
  sentAt     DateTime?
  createdAt  DateTime  @default(now())
}
